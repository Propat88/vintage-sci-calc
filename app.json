{
  "expo": {
    "name": "Vintage Sci Calculator",
    "slug": "vintage-sci-calc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/vintage25-icon.png",
    "scheme": "vintagescicalc",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/vintage25-icon.png"
    },
    "android": {
      "package": "com.patricio.vintagescicalc",
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/vintage25-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8321683523431977~3740848732",
          "iosAppId": "ca-app-pub-8321683523431977~3740848732",
          "delayAppMeasurementInit": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraProguardRules": "-keep class com.google.android.gms.internal.consent_sdk.** { *; }"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee98a243-4b68-4a94-ad57-1ba89ace35cb"
      }
    }
  }
}
