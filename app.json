{
  "expo": {
    "name": "Vintage 25 Calc",
    "slug": "CalculadoraHP",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hp25-icon.png",
    "scheme": "calculadorahp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/hp25-icon.png"
    },
    "android": {
      "package": "com.patricio.vintage25calc",
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/hp25-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee98a243-4b68-4a94-ad57-1ba89ace35cb"
      }
    }
  }
}
